# Zonder sleutels: de app gebruikt OSRM = autoroute over wegen; kaartweergave = MapLibre + OSM-tegels.
# Met sleutel: Google Maps JavaScript API + Directions (ingeschakeld in Cloud Console) = kaart + route
# in de app (zelfde motor als maps.google.com). Billing, $200 tegoed/maand). Beperk de sleutel tot je domein.
VITE_GOOGLE_MAPS_API_KEY=

# Extra fallback: OpenRouteService — https://openrouteservice.org/dev/#/signup
VITE_OPENROUTE_API_KEY=

# Optioneel: eigen MapLibre style-URL (vector). Leeg = standaard OpenStreetMap-tegels in de app.
# VITE_MAPLIBRE_STYLE_URL=

