# Zonder sleutels: de app gebruikt al automatisch OSRM = autoroute over wegen (geen vogelvlucht).
# Optioneel Google =zelfde motor als maps.google.com (billing, $200 tegoed/maand).
# https://console.cloud.google.com/ — Maps JavaScript API + sleutel beperken tot je domein.
VITE_GOOGLE_MAPS_API_KEY=

# Extra fallback: OpenRouteService — https://openrouteservice.org/dev/#/signup
VITE_OPENROUTE_API_KEY=

# Optioneel: eigen MapLibre style-URL (vector). Leeg = standaard OpenStreetMap-tegels in de app.
# VITE_MAPLIBRE_STYLE_URL=

